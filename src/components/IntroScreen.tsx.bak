import { motion } from 'motion/react';
import { Play, Sparkles, Flame, Film, ChevronRight } from 'lucide-react';
import { TelegramUser } from '../App';

interface IntroScreenProps {
  onExplore: () => void;
  user: TelegramUser | null;
}

export function IntroScreen({ onExplore, user }: IntroScreenProps) {
  return (
    <div className="fixed inset-0 z-40 flex flex-col items-center justify-center bg-transparent text-white overflow-hidden">
      {/* Animated Background Elements */}
      <div className="absolute inset-0 overflow-hidden pointer-events-none">
        <motion.div 
          animate={{ rotate: 360 }}
          transition={{ duration: 50, repeat: Infinity, ease: "linear" }}
          className="absolute -top-[20%] -right-[20%] w-[70vw] h-[70vw] rounded-full bg-blue-600/20 blur-[80px]"
        />
        <motion.div 
          animate={{ rotate: -360 }}
          transition={{ duration: 40, repeat: Infinity, ease: "linear" }}
          className="absolute -bottom-[20%] -left-[20%] w-[60vw] h-[60vw] rounded-full bg-purple-600/20 blur-[80px]"
        />
      </div>

      <div className="relative z-10 flex flex-col items-center text-center px-6 w-full max-w-md">
        
        {/* User Profile Avatar */}
        <motion.div
          initial={{ opacity: 0, scale: 0.5 }}
          animate={{ opacity: 1, scale: 1 }}
          transition={{ duration: 0.8, type: "spring", bounce: 0.5 }}
          className="relative mb-6"
        >
          {user?.photo_url ? (
            <img 
              src={user.photo_url} 
              alt={user.first_name} 
              className="w-24 h-24 rounded-full object-cover border-4 border-white/10 shadow-[0_0_30px_rgba(168,85,247,0.4)] animate-float-subtle"
            />
          ) : (
            <div className="w-24 h-24 rounded-full bg-gradient-to-tr from-purple-600 to-blue-500 flex items-center justify-center border-4 border-white/10 shadow-[0_0_30px_rgba(168,85,247,0.4)] animate-float-subtle">
              <Sparkles size={40} className="text-white" />
            </div>
          )}
          <motion.div 
            initial={{ scale: 0 }}
            animate={{ scale: 1 }}
            transition={{ delay: 0.5, type: "spring" }}
            className="absolute -bottom-2 -right-2 bg-green-500 w-6 h-6 rounded-full border-2 border-[#0f0c29] flex items-center justify-center"
          >
            <div className="w-2 h-2 bg-white rounded-full animate-pulse" />
          </motion.div>
        </motion.div>

        {/* Text Sequence */}
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.3, duration: 0.8 }}
          className="glass-panel p-6 rounded-3xl mb-10 relative overflow-hidden"
        >
          <div className="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-blue-500/10" />
          <h1 className="relative z-10 text-3xl sm:text-4xl font-display font-extrabold mb-4 tracking-tight leading-tight drop-shadow-lg">
            সিনেমাটিক জগতে <br />
            <span className="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400">
              স্বাগতম, {user?.first_name || 'বন্ধু'}!
            </span>
          </h1>
          <p className="relative z-10 text-gray-300 text-base sm:text-lg leading-relaxed font-medium">
            দেশের সবচেয়ে প্রিমিয়াম স্ট্রিমিং প্ল্যাটফর্মে আপনাকে স্বাগতম। আনলিমিটেড <span className="text-white font-bold">মুভি</span>, <span className="text-white font-bold">ওয়েব সিরিজ</span> এবং <span className="text-red-400 font-bold">এক্সক্লুসিভ</span> কন্টেন্ট উপভোগ করুন একদম ফ্রি-তে।
          </p>
        </motion.div>

        {/* CTA Button with Pulsing Animation */}
        <motion.button
          initial={{ opacity: 0, y: 30 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.6, duration: 0.6, type: "spring", stiffness: 200 }}
          onClick={onExplore}
          className="group relative w-full h-16 rounded-2xl bg-white/10 text-white font-bold text-lg tracking-wide overflow-hidden shadow-[0_10px_40px_rgba(0,0,0,0.5)] border border-white/20 transition-transform active:scale-95 flex items-center justify-center gap-3"
        >
          {/* Animated Gradient Background */}
          <motion.div 
            animate={{ 
              backgroundPosition: ['0% 50%', '100% 50%', '0% 50%'],
            }}
            transition={{ duration: 5, repeat: Infinity, ease: "linear" }}
            className="absolute inset-0 bg-gradient-to-r from-blue-600 via-purple-600 to-blue-600 bg-[length:200%_200%] opacity-80 group-hover:opacity-100 transition-opacity duration-300" 
          />
          
          <span className="relative z-10 flex items-center gap-2">
            <span className="animate-pulse">🔥</span> 
            শুরু করুন
          </span>
          
          {/* Bouncing Arrow */}
          <motion.div
            animate={{ x: [0, 5, 0] }}
            transition={{ duration: 1.5, repeat: Infinity, ease: "easeInOut" }}
            className="relative z-10"
          >
            <ChevronRight size={24} />
          </motion.div>
        </motion.button>

        {/* Subtle hint text */}
        <motion.p
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ delay: 1, duration: 1 }}
          className="mt-6 text-xs text-gray-400 font-medium tracking-widest uppercase"
        >
          Tap to enter the universe
        </motion.p>
      </div>
    </div>
  );
